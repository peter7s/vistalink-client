# Copy this file to `.env` and fill in your real values.

# ─── VistaLink ────────────────────────────────────────────────────────────────
VL_API_KEY=vl_test_paste_your_real_key_here

# mock   = use local fixtures, no key needed
# live   = hit the real VistaLink API
VL_MODE=live

# Base URL — override only if VistaLink gives you a different env (staging, etc.)
VL_API_BASE=https://api.vistalink.com

# Mock-only knob: fixture (handcrafted JSON) or faker (random schema-valid hotels)
VL_MOCK_MODE=fixture

# Where the CLI looks for the proxy. Change if you run uvicorn on a different port.
VL_PROXY=http://localhost:8787

# ─── Agent harness (optional — only needed for `python -m cli.agent`) ─────────
ANTHROPIC_API_KEY=sk-ant-paste-if-using-claude
OPENAI_API_KEY=sk-paste-if-using-gpt
